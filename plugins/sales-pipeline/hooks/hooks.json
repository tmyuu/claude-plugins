{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/inject-sales-state.sh\"",
            "timeout": 15,
            "statusMessage": "営業パイプライン状態を取得中..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/auto-advance-stage.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
